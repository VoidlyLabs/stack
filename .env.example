# Stack
STACK_NAME=voidly
MONGO_VERSION=7

# Max old-space size for npm build steps. Lower to 512 on tiny VPSes, raise if Next build fails.
NODE_BUILD_MEMORY_MB=768

# Service repositories.
CORE_PATH=./core
ADMIN_PATH=./admin
APP_PATH=./app

# Dockerfile paths are relative to each service build context.
CORE_DOCKERFILE=../docker/node/Dockerfile
ADMIN_DOCKERFILE=../docker/node/Dockerfile
APP_DOCKERFILE=../docker/node/Dockerfile

# Bind published ports. Use 0.0.0.0 to expose on the server network.
CORE_BIND=0.0.0.0
ADMIN_BIND=0.0.0.0
APP_BIND=0.0.0.0
CORE_PORT=3000
ADMIN_PORT=3001
APP_PORT=3002

# Public URLs used by browser-side clients. Replace SERVER_IP before testing from your browser.
PUBLIC_CORE_URL=http://SERVER_IP:3000
ADMIN_PUBLIC_URL=http://SERVER_IP:3001
APP_PUBLIC_URL=http://SERVER_IP:3002

# Keep development for direct HTTP auth cookies. Use production only when core is behind HTTPS.
CORE_NODE_ENV=development

# Cookie domain for cross-subdomain auth (e.g. .example.com covers api.example.com and admin.example.com).
# Leave empty for single-domain or IP deployments.
COOKIE_DOMAIN=

# MongoDB
MONGO_USERNAME=voidly
MONGO_PASSWORD=change-me-mongo-password
MONGO_DATABASE=voidly

# Initial admin user (created on first startup if not exists)
INITIAL_USER_USERNAME=admin
INITIAL_USER_PASSWORD=change-me-initial-password

# Core auth/storage
SERVER_JWT_SECRET=change-me-server-jwt-secret
CLIENT_JWT_SECRET=change-me-client-jwt-secret
PASSWORD_SALT_ROUNDS=12
CLIENT_TOKEN_MAX_AGE_HRS=72
USER_TOKEN_MAX_AGE_HRS=48
USER_TOKEN_COOKIE=user_access_token
CLIENT_TOKEN_COOKIE=client_access_token